page {
  background: #fafafa;
  color: #2d2d2d;
  font-size: 28rpx;
}

view,
text,
button,
navigator {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100%;
  padding: 32rpx 24rpx 32rpx;
}

.page-shell.with-bottom-space {
  padding-bottom: 180rpx;
}

.soft-top {
  margin: -32rpx -24rpx 0;
  padding: 32rpx 24rpx 28rpx;
  background: linear-gradient(180deg, rgba(255, 140, 105, 0.1) 0%, rgba(255, 140, 105, 0.03) 55%, rgba(250, 250, 250, 0) 100%);
}

.hero-card,
.panel,
.list-card,
.stat-card,
.record-card,
.empty-card {
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
}

.hero-card,
.panel,
.list-card,
.record-card,
.empty-card {
  padding: 28rpx;
}

.section-title {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #2d2d2d;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.small-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d2d2d;
}

.primary-btn,
.ghost-btn,
.danger-btn,
.secondary-btn {
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1.2;
  padding: 24rpx 28rpx;
}

.primary-btn::after,
.ghost-btn::after,
.danger-btn::after,
.secondary-btn::after {
  border: none;
}

.primary-btn {
  background: #ff8c69;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 105, 0.32);
}

.secondary-btn {
  background: #f6f6f7;
  color: #4b4b4f;
}

.ghost-btn {
  background: #fff4ef;
  color: #ff8c69;
}

.danger-btn {
  background: #fdecec;
  color: #e57373;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.muted {
  color: #8e8e93;
}

.icon-badge {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(255, 140, 105, 0.28);
  background: linear-gradient(135deg, #ff8c69, #ffb299);
}
